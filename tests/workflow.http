### 1. Signup as FARMER
POST http://localhost:3000/api/auth/signup
Content-Type: application/json

{
  "email": "farmer@test.com",
  "password": "farmerpass",
  "role": "FARMER",
  "name": "Jean Fermier",
  "phone": "+242000001",
  "location": "Brazzaville"
}

### 2. Signup as WORKER
POST http://localhost:3000/api/auth/signup
Content-Type: application/json

{
  "email": "worker@test.com",
  "password": "workerpass",
  "role": "WORKER",
  "name": "Ali Travailleur",
  "phone": "+242000002",
  "location": "Brazzaville"
}

### 3. LOGIN as FARMER
POST http://localhost:3000/api/auth/login
Content-Type: application/json

{
  "email": "farmer@test.com",
  "password": "farmerpass"
}

### 4. LOGIN as WORKER
POST http://localhost:3000/api/auth/login
Content-Type: application/json

{
  "email": "worker@test.com",
  "password": "workerpass"
}

### 5. Create Job as FARMER
POST http://localhost:3000/api/jobs
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6ImMxM2IxMzVlLWU2OTMtNDFlMS04Njk1LTk1NjdjOWU4Mzk5OCIsInJvbGUiOiJGQVJNRVIiLCJpYXQiOjE3NTAyMzc5NzQsImV4cCI6MTc1MDMyNDM3NH0.WwRLKJJhU3XyM3F305CLXqJOtDfOnQbIR60wcvfi4N4
Content-Type: application/json

{
  "title": "Récolte de manioc",
  "description": "2 jours de récolte",
  "location": "Brazzaville",
  "max_workers": 1
}

### 6. WORKER applies to job
POST http://localhost:3000/api/jobs/c50f1ef3-cfb2-44c2-a126-bf6590617ba4/apply
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6ImFlMTE4ODdjLTVmMTYtNDQyNC1hYjY2LWMxNzA5MjU2NTY5ZSIsInJvbGUiOiJXT1JLRVIiLCJpYXQiOjE3NTAyMzc4MzUsImV4cCI6MTc1MDMyNDIzNX0.0jVCbPKVioKB0kt9QaoopQPcYGiLRVafxF82PyUSU5o
Content-Type: application/json

{
  "message": "Disponible tout de suite !"
}

### 7. FARMER accepts application
PATCH http://localhost:3000/api/jobs/application/96746d5a-2920-4f68-b0d5-1b8da63a74f9/status
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6ImMxM2IxMzVlLWU2OTMtNDFlMS04Njk1LTk1NjdjOWU4Mzk5OCIsInJvbGUiOiJGQVJNRVIiLCJpYXQiOjE3NTAyMzc5NzQsImV4cCI6MTc1MDMyNDM3NH0.WwRLKJJhU3XyM3F305CLXqJOtDfOnQbIR60wcvfi4N4
Content-Type: application/json

{
  "status": "ACCEPTED"
}

### 8. WORKER re-applies to same job (should fail)
POST http://localhost:3000/api/jobs/c50f1ef3-cfb2-44c2-a126-bf6590617ba4/apply
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6ImFlMTE4ODdjLTVmMTYtNDQyNC1hYjY2LWMxNzA5MjU2NTY5ZSIsInJvbGUiOiJXT1JLRVIiLCJpYXQiOjE3NTAyMzc4MzUsImV4cCI6MTc1MDMyNDIzNX0.0jVCbPKVioKB0kt9QaoopQPcYGiLRVafxF82PyUSU5o
Content-Type: application/json

{
  "message": "Encore dispo !"
}

### 10. FARMER marks job as complete
PATCH http://localhost:3000/api/jobs/c50f1ef3-cfb2-44c2-a126-bf6590617ba4/complete
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6ImMxM2IxMzVlLWU2OTMtNDFlMS04Njk1LTk1NjdjOWU4Mzk5OCIsInJvbGUiOiJGQVJNRVIiLCJpYXQiOjE3NTAyMzc5NzQsImV4cCI6MTc1MDMyNDM3NH0.WwRLKJJhU3XyM3F305CLXqJOtDfOnQbIR60wcvfi4N4

